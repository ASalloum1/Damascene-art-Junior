# Origin (and optional path prefix) of the Laravel backend.
# Leave blank to issue requests against the same origin that serves the SPA.
# Trailing slashes are stripped at runtime, so either form is fine:
#   VITE_API_BASE_URL=http://localhost:8000
#   VITE_API_BASE_URL=http://localhost:8000/
VITE_API_BASE_URL=

# When `true`, the product-images API client uses the in-memory mock so the
# UI can be developed and demoed without the backend. Flip to `false` to
# point at the real Laravel endpoints.
VITE_PRODUCT_IMAGES_USE_MOCK=true
