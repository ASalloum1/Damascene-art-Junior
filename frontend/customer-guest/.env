# API Configuration for Special Orders
VITE_API_BASE_URL=https://unincriminating-nola-phonogramically.ngrok-free.dev
VITE_SPECIAL_ORDERS_BEARER_TOKEN=your_bearer_token_here

# Visual Search — set to "true" to use the in-process mock client instead
# of the real backend. Useful while the Laravel endpoints are still under
# development. Any other value (or unset) uses the real client.
VITE_VISUAL_SEARCH_USE_MOCK=false

# Chatbot — set to "true" to use the in-process mock client (no backend
# required). Any other value (or unset) uses the real client.
VITE_CHATBOT_USE_MOCK=true
