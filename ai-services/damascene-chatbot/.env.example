# Skywork Provider (OpenAI-compatible)
LLM_BASE_URL=https://skywork-proxy.onrender.com/v1
LLM_API_KEY=Ahmad_Investor_2026
LLM_MODEL=gemini-3.1-pro

# Embedding model — runs locally on CPU
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ChromaDB path
CHROMA_DB_PATH=./chroma_db

# Knowledge base file
KB_FILE_PATH=./damascene_knowledge_base.json

# Server config
HOST=0.0.0.0
PORT=8000

# Number of context chunks to retrieve
TOP_K=5

# Security — leave API_KEY empty to disable auth (local dev).
# In production set a strong random value; clients must send it as
# the "X-API-Key" header on /chat, /ingest, /search.
API_KEY=

# Comma-separated allowed CORS origins, or "*" for any origin.
# Example: CORS_ORIGINS=https://damascene-art.com,https://staging.damascene-art.com
CORS_ORIGINS=*
